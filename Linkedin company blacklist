      .licb-panel-footer button, .licb-import-label {
        flex: 1; text-align: center;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
        color: #8fa0af; border-radius: 8px; padding: 5px 8px;
        font-size: 11px; font-weight: 600; cursor: pointer; font-family: inherit;
      }
      .licb-panel-footer button:hover, .licb-import-label:hover {
        background: rgba(255,255,255,0.11); color: #c8d8e4;
