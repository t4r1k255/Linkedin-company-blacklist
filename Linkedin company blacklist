      #licb-clear-all:hover { background: rgba(220,38,38,0.15) !important; }

      @media (max-width: 900px) {
        #licb-badge { top: 60px; left: 8px; }
        #licb-panel { left: 8px; width: calc(100vw - 16px); }
      }
    `;
  }

  // ─── OBSERVER & ZAMANLAYICILAR ────────────────────────────────────────────────
  let rafId    = null;
  let mutTimer = null;

  function scheduleRefresh() {
    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(() => { rafId = null; processCards(); });
  }

  const observer = new MutationObserver(() => {
    if (mutTimer) return;
    mutTimer = setTimeout(() => { mutTimer = null; scheduleRefresh(); }, 180);
  });

  // ─── ROTA TAKİBİ ─────────────────────────────────────────────────────────────
  let lastPath = location.pathname;

  function onRouteChange() {
    if (location.pathname === lastPath) return;
    lastPath = location.pathname;
    setTimeout(scheduleRefresh, 350);
    setTimeout(scheduleRefresh, 900);
    setTimeout(scheduleRefresh, 2000);
  }

  function patchHistory(method) {
    const orig = history[method].bind(history);
    history[method] = function (...args) {
      const r = orig(...args);
      onRouteChange();
      return r;
    };
  }

  // ─── BAŞLATMA ────────────────────────────────────────────────────────────────
  function init() {
    injectCSS();

    if (isJobsPage()) {
      scheduleRefresh();
      setTimeout(scheduleRefresh, 600);
      setTimeout(scheduleRefresh, 1800);
    }

    observer.observe(document.body, { childList: true, subtree: true });

    patchHistory('pushState');
    patchHistory('replaceState');
    window.addEventListener('popstate', onRouteChange);

    setInterval(() => { if (isJobsPage()) scheduleRefresh(); }, 2500);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }

})();
